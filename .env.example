# ─── Medusa Backend ───────────────────────────────────────────────────────────
# Your deployed Medusa backend URL.
# - Local dev:  http://localhost:9000
# - Railway:    https://your-app.railway.app
# - Render:     https://your-app.onrender.com
# If this is NOT set, the app runs in offline mode using seed data.
VITE_MEDUSA_BACKEND_URL=

# ─── Medusa Publishable API Key ───────────────────────────────────────────────
# Required for Medusa v2. Create one in the Medusa Admin:
#   Settings → API Key Management → Create API Key
VITE_MEDUSA_PUBLISHABLE_KEY=

# ─── Gemini (AI Studio) ───────────────────────────────────────────────────────
# Auto-injected by AI Studio from user secrets.
GEMINI_API_KEY=

# ─── App URL ──────────────────────────────────────────────────────────────────
# The public URL of this app (used for SEO, OG tags, redirects).
# - Local:      http://localhost:3000
# - Production: https://your-site.pages.dev
APP_URL=

# ─── Supabase ─────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── iyzico Payment System (Production/Sandbox) ──────────────────────────────
# Get these from iyzico Merchant Panel
IYZICO_API_KEY=your-iyzico-api-key
IYZICO_SECRET_KEY=your-iyzico-secret-key
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com # Use https://api.iyzipay.com for production
IYZICO_CALLBACK_URL=https://your-project.supabase.co/functions/v1/iyzico-callback
